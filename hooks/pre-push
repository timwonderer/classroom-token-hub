#!/bin/bash
#
# Pre-push hook to check for multiple Alembic migration heads
# This prevents pushing changes that would create migration conflicts
#

# ANSI color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Only check if migrations directory exists
if [ ! -d "migrations" ]; then
    exit 0
fi

# Resolve a Python interpreter that matches the project environment.
PYTHON_BIN=""
if [ -n "${VIRTUAL_ENV:-}" ] && [ -x "${VIRTUAL_ENV}/bin/python" ]; then
    PYTHON_BIN="${VIRTUAL_ENV}/bin/python"
elif [ -x "venv/bin/python" ]; then
    PYTHON_BIN="venv/bin/python"
elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python)"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python3)"
else
    echo "⚠️  Warning: no Python interpreter found, skipping migration head check"
    exit 0
fi

echo "🔍 Checking for multiple migration heads..."
echo "   Using Python: ${PYTHON_BIN}"

# Check for multiple heads using Python
"${PYTHON_BIN}" << 'PYTHON_SCRIPT'
import sys
import os

try:
    # Change to migrations directory
    if not os.path.exists('migrations/alembic.ini'):
        print("✓ No migrations directory found, skipping check")
        sys.exit(0)

    from alembic.script import ScriptDirectory
    from alembic.config import Config

    config = Config('migrations/alembic.ini')
    config.set_main_option('script_location', 'migrations')
    script = ScriptDirectory.from_config(config)
    heads = list(script.get_revisions('heads'))

    if len(heads) > 1:
        print(f"\n❌ ERROR: {len(heads)} migration heads detected!")
        print("\nThis means you have divergent migration paths that will cause conflicts.")
        print("\nTo fix this, create a merge migration:")
        print("  flask db merge heads -m 'Merge migration heads'")
        print("\nOr sync with main before creating your migration:")
        print("  git fetch origin main")
        print("  git merge origin/main")
        print("  # Then recreate your migration")
        print("\n⚠️  Push blocked to prevent migration conflicts.")
        sys.exit(1)
    else:
        print(f"✓ Migration heads check passed ({len(heads)} head)")

except ImportError:
    print(f"⚠️  Warning: alembic not installed in {sys.executable}, skipping migration head check")
    sys.exit(0)
except Exception as e:
    print(f"⚠️  Warning: Could not check migration heads: {e}")
    print("   Allowing push to continue...")
    sys.exit(0)

PYTHON_SCRIPT

exit_code=$?

if [ $exit_code -ne 0 ]; then
    echo ""
    echo -e "${RED}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║         Push blocked due to migration conflicts           ║${NC}"
    echo -e "${RED}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "To bypass this check (not recommended):"
    echo "  git push --no-verify"
    echo ""
    exit 1
fi

exit 0
