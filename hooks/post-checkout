#!/bin/bash
# Branch-aware database switching hook.
# Protected v2 branches always use classroom_economy to avoid migration-chain corruption.

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
# shellcheck source=/dev/null
source "$REPO_ROOT/scripts/lib/db_branch_config.sh"

BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
ENV_FILE="$REPO_ROOT/.env"

if [ ! -f "$ENV_FILE" ]; then
  echo "Warning: .env file not found"
  exit 0
fi

target_name="$(db_name_for_branch "$BRANCH_NAME")"
target_url="$(db_url_for_name "$target_name")"

if [ -z "$target_url" ]; then
  echo "Error: could not resolve database URL for branch '$BRANCH_NAME'"
  exit 1
fi

if grep -q "^DATABASE_URL=" "$ENV_FILE"; then
  current_url=$(grep "^DATABASE_URL=" "$ENV_FILE" | head -n 1 | cut -d= -f2-)
  if [ -n "$current_url" ] && ! is_allowed_local_db_url "$current_url"; then
    echo "Error: refusing to overwrite non-local DATABASE_URL in .env"
    echo "  Current: $current_url"
    echo "  Allowed local URLs are limited to classroom_economy and production_dev."
    exit 1
  fi
  escaped_target_url=$(printf '%s' "$target_url" | sed 's/[&/|]/\\&/g')
  sed -i.bak "s|^DATABASE_URL=.*|DATABASE_URL=$escaped_target_url|" "$ENV_FILE"
  rm -f "$ENV_FILE.bak"
else
  echo "DATABASE_URL=$target_url" >> "$ENV_FILE"
fi

echo "✓ Switched to $target_name database ($BRANCH_NAME branch)"
